+                return "\($0.title): \(snippet)"
+            }.joined(separator: "\n- ")
+
+        let dueLine = dueDate.map { "Resolved deadline: \(formatter.string(from: $0))." } ?? "Resolved deadline: not fixed in memory."
+
+        return """
