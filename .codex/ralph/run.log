+           let response = runCodexMemCLI(invocation: invocation, query: query, limit: limit)
+        {
+            let hits = cliHits(from: response)
+            if !hits.isEmpty {
+                return hits
+            }
+        }
+
+        return CodexMemorySearchProvider.search(question: query, limit: limit, dbPath: codexMemDBPath).map {
