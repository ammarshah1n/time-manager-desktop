+
+    override func viewDidMoveToSuperview() {
+        super.viewDidMoveToSuperview()
+        DispatchQueue.main.async { [weak self] in
+            self?.configureWindow()
+        }
+    }
+
+    func configureWindow() {
+        guard let window else { return }
+
+        window.styleMask.insert(.titled)
