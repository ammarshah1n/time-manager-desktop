+        let weekdayMap: [(String, Int)] = [
+            ("monday", 2),
+            ("tuesday", 3),
+            ("wednesday", 4),
+            ("thursday", 5),
+            ("friday", 6),
+            ("saturday", 7),
+            ("sunday", 1)
+        ]
+
