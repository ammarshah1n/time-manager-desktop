+private final class QueryCapture: @unchecked Sendable {
+    private let lock = NSLock()
+    private var storage: [String] = []
+
+    var queries: [String] {
+        lock.lock()
+        defer { lock.unlock() }
+        return storage
+    }
+
+    func append(_ query: String) {
+        lock.lock()
+        storage.append(query)
+        lock.unlock()
+    }
