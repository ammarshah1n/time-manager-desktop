+            .filter { SpacedRepetitionEngine.isDue($0, now: now) }
+            .sorted { lhs, rhs in
+                if lhs.nextDue != rhs.nextDue {
+                    return lhs.nextDue < rhs.nextDue
+                }
+                return lhs.question.localizedCaseInsensitiveCompare(rhs.question) == .orderedAscending
+            }
+    }
