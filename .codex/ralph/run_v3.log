+            question: question,
+            options: options,
+            correctIndex: correctIndex,
+            explanation: explanation,
+            sourceTitle: sourceTitle,
+            easeFactor: easeFactor,
+            interval: interval,
+            nextDue: nextDue
+        )
+    }
 }
 
