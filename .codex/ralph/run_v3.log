+
+        var strippedTitle = trimmedInput
+
+        if let dueRange = dueMatch?.range {
+            strippedTitle = replacingCharacters(in: strippedTitle, range: dueRange, with: " ")
+        }
+
+        if let importanceRange = importanceMatch?.range {
+            strippedTitle = replacingCharacters(in: strippedTitle, range: importanceRange, with: " ")
+        }
+
+        if let subject {
+            strippedTitle = removingSubject(subject, from: strippedTitle)
+        }
