+        DispatchQueue.main.asyncAfter(deadline: .now() + 0.5) {
+            guard token == pendingSaveToken else { return }
+            onSaveNotes(text)
+        }
+    }
+
+    private func flushPendingSave() {
+        pendingSaveToken += 1
+        onSaveNotes(notesDraft)
+    }
+}
