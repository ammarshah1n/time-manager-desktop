+            .filter { !SpacedRepetitionEngine.isDue($0, now: now) }
+            .min { $0.nextDue < $1.nextDue }
+
+        guard let upcoming else { return nil }
+        return SpacedRepetitionEngine.daysUntilDue(upcoming, now: now)
