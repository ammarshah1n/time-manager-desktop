+    init(calendar: Calendar = .current) {
+        self.calendar = calendar
+    }
+
+    func parse(_ input: String, now: Date = .now) -> ParsedTask {
+        let trimmedInput = input.trimmingCharacters(in: .whitespacesAndNewlines)
