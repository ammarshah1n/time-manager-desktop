+        }
+
+        let subject = SubjectCatalog.matchingSubject(in: trimmedInput)
+        let importanceMatch = firstMatch(
+            pattern: #"\b(?:importance|priority|imp)\s*[:=]?\s*(\d{1,2})\b"#,
+            in: trimmedInput
+        )
