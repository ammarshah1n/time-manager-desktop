+    func nextQuizReviewDays(for subject: String, now: Date = .now) -> Int? {
+        let upcoming = quizCards(for: subject)
+            .filter { !SpacedRepetitionEngine.isDue($0, now: now) }
+            .min { $0.nextDue < $1.nextDue }
+
