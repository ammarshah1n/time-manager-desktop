+    func pomodoroTrend(referenceDate: Date = .now, days: Int = 7) -> [PomodoroDayStat] {
+        let safeDays = max(1, days)
+        let calendar = Calendar.current
+        let referenceDay = calendar.startOfDay(for: referenceDate)
+
