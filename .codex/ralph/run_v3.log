+          "source": "Seqta",
+          "subject": "Economics",
+          "estimateMinutes": 45,
+          "confidence": 3,
+          "importance": 5,
+          "dueDate": null,
+          "energy": "Medium",
+          "isCompleted": false,
+          "completedAt": null
+        }
+        """
+
+        let task = try JSONDecoder().decode(TaskItem.self, from: Data(json.utf8))
+        #expect(task.notes.isEmpty)
