+            "2026-03-21": 0,
+            "2026-03-22": 2,
+            "2026-03-23": 1,
+            "2026-03-24": 0,
+            "2026-03-25": 3,
+            "2026-03-26": 2,
+            "2026-03-27": 1
+        ]
+
+        #expect(store.currentPomodoroStreak(referenceDate: today) == 3)
+        #expect(store.pomodoroCount(on: today) == 1)
+        #expect(store.pomodoroTrend(referenceDate: today).map(\.count) == [0, 2, 1, 0, 3, 2, 1])
+    }
