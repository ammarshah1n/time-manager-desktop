+    func quizCards(for subject: String) -> [QuizQuestion] {
+        let canonicalSubject = canonicalSubjectName(subject)
+        guard !canonicalSubject.isEmpty else { return [] }
+        return quizQuestionsBySubject[canonicalSubject] ?? []
