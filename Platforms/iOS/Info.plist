<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleDevelopmentRegion</key>
  <string>en</string>
  <key>CFBundleExecutable</key>
  <string>$(EXECUTABLE_NAME)</string>
  <key>CFBundleIdentifier</key>
  <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
  <key>CFBundleInfoDictionaryVersion</key>
  <string>6.0</string>
  <key>CFBundleName</key>
  <string>$(PRODUCT_NAME)</string>
  <key>CFBundleDisplayName</key>
  <string>Timed</string>
  <key>CFBundleShortVersionString</key>
  <string>$(MARKETING_VERSION)</string>
  <key>CFBundleVersion</key>
  <string>$(CURRENT_PROJECT_VERSION)</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>LSRequiresIPhoneOS</key>
  <true/>
  <key>MinimumOSVersion</key>
  <string>18.0</string>
  <key>UIApplicationSceneManifest</key>
  <dict>
    <key>UIApplicationSupportsMultipleScenes</key>
    <false/>
    <key>UISceneConfigurations</key>
    <dict/>
  </dict>
  <key>UISupportedInterfaceOrientations~iphone</key>
  <array>
    <string>UIInterfaceOrientationPortrait</string>
  </array>
  <key>UISupportedInterfaceOrientations~ipad</key>
  <array>
    <string>UIInterfaceOrientationPortrait</string>
    <string>UIInterfaceOrientationPortraitUpsideDown</string>
    <string>UIInterfaceOrientationLandscapeLeft</string>
    <string>UIInterfaceOrientationLandscapeRight</string>
  </array>
  <key>UILaunchScreen</key>
  <dict/>
  <!-- Permissions strings — Yasser sees these in iOS prompts. Honest copy: Timed never acts. -->
  <key>NSMicrophoneUsageDescription</key>
  <string>Timed uses your microphone for the orb conversation and morning planning. Recording is live only — nothing persists beyond the session.</string>
  <key>NSSpeechRecognitionUsageDescription</key>
  <string>Timed transcribes your voice locally during orb conversations.</string>
  <key>NSCalendarsUsageDescription</key>
  <string>Timed reads your calendar to spot conflicts and plan your day. Read-only — Timed never edits, creates, or invites.</string>
  <key>NSContactsUsageDescription</key>
  <string>Optional. If granted, Timed enriches relationship cards with names from your contacts. Stays on-device.</string>
  <key>NSUserNotificationsUsageDescription</key>
  <string>Timed sends scored alerts when its intelligence engine detects a high-priority signal — replies due, deadlines, prep gaps.</string>
  <!-- URL schemes — same as Mac for OAuth + MSAL fallback (Universal Links may replace later) -->
  <key>CFBundleURLTypes</key>
  <array>
    <dict>
      <key>CFBundleURLName</key>
      <string>Timed OAuth Callback</string>
      <key>CFBundleURLSchemes</key>
      <array><string>timed</string></array>
    </dict>
    <dict>
      <key>CFBundleURLName</key>
      <string>MSAL Auth</string>
      <key>CFBundleURLSchemes</key>
      <array><string>msauth.com.timed.app</string></array>
    </dict>
  </array>
  <!-- MSAL needs to query the broker / Authenticator app via canOpenURL (iOS-only) -->
  <key>LSApplicationQueriesSchemes</key>
  <array>
    <string>msauthv2</string>
    <string>msauthv3</string>
  </array>
  <!-- Background modes for orb continuity, BGTaskScheduler, silent push -->
  <key>UIBackgroundModes</key>
  <array>
    <string>audio</string>
    <string>fetch</string>
    <string>processing</string>
    <string>remote-notification</string>
  </array>
  <key>BGTaskSchedulerPermittedIdentifiers</key>
  <array>
    <string>com.timed.app.bgRefresh.email</string>
    <string>com.timed.app.bgProcessing.synthesis</string>
  </array>
  <!-- Status bar style (full-screen orb experience) -->
  <key>UIStatusBarStyle</key>
  <string>UIStatusBarStyleDefault</string>
  <key>UIViewControllerBasedStatusBarAppearance</key>
  <true/>
</dict>
</plist>
