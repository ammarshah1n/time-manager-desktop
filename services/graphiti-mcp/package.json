{
  "name": "graphiti-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing Graphiti temporal knowledge graph + Supabase Storage snapshots. Bearer-auth HTTP transport for Fly.io.",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.11.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "@supabase/supabase-js": "^2.45.4",
    "express": "^4.21.1",
    "neo4j-driver": "^5.25.0",
    "node-fetch": "^3.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
