# TimeBlock Environment Variables
# Copy to .env.local and fill in values. Never commit .env.local.

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Microsoft Graph (Azure App Registration)
GRAPH_CLIENT_ID=
GRAPH_TENANT_ID=

# AI providers — server-side only. Never ship to client.
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=
DEEPGRAM_PROJECT_ID=

# ElevenLabs Conversational AI — set the agent ID from the dashboard.
# The agent's Custom LLM URL must point at /functions/v1/voice-llm-proxy.
ELEVENLABS_MORNING_AGENT_ID=

# Sentry (post-MVP)
# SENTRY_DSN=
