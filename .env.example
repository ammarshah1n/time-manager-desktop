# TimeBlock Environment Variables
# Copy to .env.local and fill in values. Never commit .env.local.

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Microsoft Graph (Azure App Registration)
GRAPH_CLIENT_ID=
GRAPH_TENANT_ID=

# AI
ANTHROPIC_API_KEY=

# Dish Me Up — hardcoded single-user UUID until login flow ships.
# Value should match public.executives.id for Yasser.
YASSER_USER_ID=

# ElevenLabs Conversational AI — set the agent ID from the dashboard.
# The agent's Custom LLM URL must point at /functions/v1/voice-llm-proxy.
ELEVENLABS_MORNING_AGENT_ID=

# Sentry (post-MVP)
# SENTRY_DSN=
